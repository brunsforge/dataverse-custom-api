{
  "name": "@brunsforge/dataverse-custom-api",
  "version": "1.0.0",
  "description": "CLI tool for managing Dataverse Custom APIs - export, edit, and sync Custom API definitions between local JSON files and Dataverse environments",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dvc": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js"
  },
  "keywords": [
    "dataverse",
    "dynamics365",
    "custom-api",
    "cli",
    "azure",
    "microsoft",
    "crm"
  ],
  "author": "Andreas Brunsmann <info@brunsforge.com> (https://github.com/brunsforge)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brunsforge/dataverse-custom-api"
  },
  "bugs": {
    "url": "https://github.com/brunsforge/dataverse-custom-api/issues"
  },
  "homepage": "https://github.com/brunsforge/dataverse-custom-api#readme",
  "files": [
    "dist",
    "src",
    "tsconfig.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/identity-cache-persistence": "^1.3.0",
    "axios": "^1.15.0",
    "commander": "^14.0.3",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}